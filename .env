# ===================== TELEGRAM CONFIG =====================
# Sən bu parametrləri doldurmalısan:

# Telegram Bot Token (@BotFather-dən al)
BOT_TOKEN=your_bot_token_here

# Telegram API parametrləri (my.telegram.org-dan)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Telegram Kanalları
SOURCE_CHANNEL=source_channel_username
TARGET_CHANNEL=@target_channel_username

# ===========================================================
# ⚠️ ÖNEMLİ: Bu faylı ASLA GitHub-a push etmə!
# .gitignore-da artıq .env var.
